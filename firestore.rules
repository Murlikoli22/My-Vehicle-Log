/**
 * This ruleset enforces a strict user-ownership model for a vehicle management application.
 * All user data is private and can only be accessed by the authenticated user who created it.
 *
 * Core Philosophy:
 * The security model is built on the principle that users have exclusive control over their own
 * information. There are no public or shared collections; every piece of data belongs to a
 * single user.
 *
 * Data Structure:
 * The Firestore database is structured hierarchically, with all user-specific data nested
 * under a top-level '/users' collection. A user's data, including their vehicles, documents,
 * and maintenance logs is stored in subcollections under their unique
 * user document: /users/{userId}/...
 *
 * Key Security Decisions:
 * - User Enumeration is Disallowed: Listing the top-level '/users' collection is explicitly
 *   forbidden to protect user privacy and prevent data scraping.
 * - Path-Based Authorization: All authorization checks rely on the {userId} wildcard in the
 *   document path. This ensures that a user can only ever access documents within their own
 *   data tree.
 * - No Public Data: Every collection is protected and requires user authentication.
 *
 * Denormalization for Authorization:
 * This ruleset leverages the Firestore path structure as a form of authorization denormalization.
 * By placing all of a user's data under `/users/{userId}`, we avoid slow and costly `get()`
 * calls to parent documents to verify ownership. For example, a rule on a maintenance log at
 * `/users/abc/vehicles/123/maintenanceLogs/xyz` can instantly verify ownership by checking if
 * the requester's UID is 'abc', without needing to read the parent vehicle or user document.
 *
 * Structural Segregation:
 * The data model naturally separates each user's data into their own document tree, which is an
 * ideal pattern for security and query performance. There is no mixing of private and public data
 * within any single collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Verifies that the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies that the requesting user's UID matches the provided userId from the path.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document being written to already exists.
     * Used to protect update and delete operations.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * A convenience function that combines an ownership check with an existence check.
     * Used for all state-changing update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    /**
     * Validates that the 'id' field of a new User document matches the document's ID (the user's UID).
     * Enforces relational integrity on creation.
     */
    function hasCorrectUserIdOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Validates that the 'userId' field in a new document matches the parent user's ID.
     * Enforces relational integrity on creation.
     */
    function hasCorrectOwnerIdOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * Validates that the 'userId' field of a document is not being changed.
     * Enforces immutability for critical ownership links.
     */
    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    /**
     * Validates that the 'vehicleId' field in a new document matches the parent vehicle's ID.
     * Enforces relational integrity on creation.
     */
    function hasCorrectVehicleIdOnCreate(vehicleId) {
      return request.resource.data.vehicleId == vehicleId;
    }

    /**
     * Validates that the 'vehicleId' field of a document is not being changed.
     * Enforces immutability for relational links.
     */
    function isVehicleIdImmutable() {
      return request.resource.data.vehicleId == resource.data.vehicleId;
    }


    // --------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------

    /**
     * @description Controls access to a user's own profile document.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own profile document.
     * @deny (list) No user, authenticated or not, can list all users in the collection.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && hasCorrectUserIdOnCreate(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      // --------------------------------------------------------------------
      // Vehicle and Subcollection Rules
      // --------------------------------------------------------------------

      /**
       * @description Controls access to a user's vehicles.
       * @path /users/{userId}/vehicles/{vehicleId}
       * @allow (create) The user can add a new vehicle to their own profile.
       * @deny (get) User 'A' cannot read a vehicle document belonging to User 'B'.
       * @principle Enforces document ownership for all operations based on the path.
       */
      match /vehicles/{vehicleId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && hasCorrectOwnerIdOnCreate(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);

        /**
         * @description Controls access to documents for a specific vehicle.
         * @path /users/{userId}/vehicles/{vehicleId}/documents/{documentId}
         * @allow (list) The vehicle owner can list all documents for their vehicle.
         * @deny (update) A user cannot update a document for a vehicle they do not own.
         * @principle Inherits ownership from the parent path, ensuring only the vehicle owner can manage related documents.
         */
        match /documents/{documentId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && hasCorrectVehicleIdOnCreate(vehicleId);
          allow update: if isExistingOwner(userId) && isVehicleIdImmutable();
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Controls access to maintenance logs for a specific vehicle.
         * @path /users/{userId}/vehicles/{vehicleId}/maintenanceLogs/{maintenanceLogId}
         * @allow (create) The vehicle owner can add a maintenance log for their vehicle.
         * @deny (delete) A user cannot delete a maintenance log for a vehicle they do not own.
         * @principle Inherits ownership from the parent path, ensuring only the vehicle owner can manage maintenance logs.
         */
        match /maintenanceLogs/{maintenanceLogId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && hasCorrectVehicleIdOnCreate(vehicleId);
          allow update: if isExistingOwner(userId) && isVehicleIdImmutable();
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}
